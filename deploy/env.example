# MicroLogist — Variables de entorno para el servidor Oracle
# Copiar a /opt/micrologist/backend/.env y completar los valores

# Base de datos (la contraseña la genera 1_setup.sh)
DATABASE_URL=postgresql+asyncpg://micrologist:TU_CONTRASEÑA_BD@localhost:5432/micrologist

# JWT — genera uno con: openssl rand -hex 32
SECRET_KEY=GENERA_UNO_CON_openssl_rand_-hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# URL del frontend en Vercel
FRONTEND_URL=https://micrologist.vercel.app

# Cron de alertas automáticas — genera uno con: openssl rand -hex 24
CRON_SECRET=GENERA_UNO_CON_openssl_rand_-hex_24

# Poner false en producción (ya es el default)
DEBUG=false

# Panel de administración — emails con acceso separados por coma
ADMIN_EMAIL=tu@email.cl
